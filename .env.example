BMW_CLIENT_ID=your-bmw-client-id-here
REST_PORT=8080
POLL_INTERVAL_MINUTES=30
# DATA_DIR defaults to /data (Docker volume mount)
# Tokens are written automatically to DATA_DIR/session.json
# VIN and container ID are cached in DATA_DIR/state.json

# CORS_ORIGINS: "*" allows all origins (default).
# Set to a comma-separated list to restrict: CORS_ORIGINS=http://localhost:3000,https://myapp.com
CORS_ORIGINS=*

# API_KEY: optional. If set, all endpoints require X-API-Key: <value> or Authorization: Bearer <value>.
# Leave empty (or unset) to allow unauthenticated access (safe for purely local deployments).
# API_KEY=

# BMW_VINS: optional comma-separated list of VINs to track.
# If unset, the primary VIN is auto-discovered from your BMW account.
# Use this when you have multiple vehicles on the same BMW account.
# BMW_VINS=WBA12345678901234,WBA98765432109876
